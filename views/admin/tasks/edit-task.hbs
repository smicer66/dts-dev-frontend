												<input value="{{bodyJS.dueDateTime}}" type="datetime-local" required class="form-control" id="dueDate" name="dueDate">
												
											</div>
											<div class="col col-md-12"  style="padding: 10px !important; ">
												<label>Task Status:<span style="color: red !important">*</span></label>
												<select required class="form-control" id="taskStatus" name="taskStatus">
													<option value>--Select Status Of The Task--</option>
													<option value="ADJOURNED">Adjourned</option>
													<option value="APPEAL_FILED">Appeal Filed</option>
													<option value="CLOSED">Case Closed</option>
													<option value="DISMISSED">Dismissed</option>
													<option value="FILED">Filed</option>
													<option value="JUDGEMENT_GIVEN">Judgment Given</option>
													<option value="PENDING">Pending</option>
													<option value="PRE_TRIAL">Pre-Trial</option>
													<option value="SETTLED">Settled</option>
													<option value="ACTIVE_TRIAL">Under Investigation</option>
												</select>
												
											</div>
											<div class="col col-md-12 bgBlack" style="padding: 10px !important">
												<input type="submit" class="btn btn-success btn-sm float-end" value="Submit">
												<div class="clear" style="clear: both !important; font-size: 1px !important; height: 1px !important">&nbsp;</div>
											</div>
